# Copy to .env for local runs; set in the Coolify project UI for production.

# Optional — enables the LLM-based relevance filter in content/news.py.
# Without a key the feeds still render (keyword filter + fail-open).
OPENROUTER_API_KEY=

# Optional — override the model used by the news filter.
NEWS_FILTER_MODEL=anthropic/claude-haiku-4-5

# Coolify auto-sets this per environment. For a local docker-compose run
# you can hard-code it to e.g. http://localhost:5001.
# SERVICE_FQDN_FOUNDERSCAP=https://founderscap.co.uk:5001
